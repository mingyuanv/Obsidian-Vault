			"y": 200
		},
		{
			"height": 120,
			"id": "a2ec80438abd96a7",
			"styleAttributes": {},
			"text": "// <span style=\"background:#d3f8b6\">定义attribute对象value1</span>\n\nstruct kobj_attribute value1 =<span style=\"background:#b1ffff\"> __ATTR</span>(value1, 0664, show_myvalue1, store_myvalue1);",
			"type": "text",
			"width": 755,
			"x": -1695,
			"y": 1460
		},
		{
			"height": 100,
			"id": "707a00b90a8ac711",
			"styleAttributes": {},
			"text": "//<span style=\"background:#d3f8b6\"> 定义了mykobj结构体</span>指针变量mykobject01\n\nstruct <span style=\"background:#affad1\">kobject</span> *mykobject01;",
			"type": "text",
			"width": 420,
			"x": -2235,
			"y": 1410
		},
		{
			"height": 100,
			"id": "4b99288a2f55bba3",
			"styleAttributes": {},
			"text": "    //<span style=\"background:#d3f8b6\"> 创建一个名为 \"mykobject01\" 的 kobject</span>，并将其添加到系统中\n\n    mykobject01 = <span style=\"background:#b1ffff\">kobject_create_and_add</span>(\"mykobject01\", NULL);",
			"type": "text",
			"width": 660,
			"x": -2355,
			"y": 1620
		},
		{
			"height": 80,
			"id": "188e6e4eb1df97bb",
			"styleAttributes": {},
			"text": "    // <span style=\"background:#d3f8b6\">释放mykobject01</span>\n\n    <span style=\"background:#fdbfff\">kobject_put</span>(mykobject01);",
			"type": "text",
			"width": 300,
			"x": -2600,
			"y": 1952
		},
		{
			"height": 83,
			"id": "bd745495af0de620",
			"styleAttributes": {},
			"text": "    // <span style=\"background:#d3f8b6\">在 mykobject01 下创建一个 sysfs 文件</span>，文件名为 \"value1\"，属性为 value1\n\n    ret = <span style=\"background:#fdbfff\">sysfs_create_file</span>(mykobject01, &value1.attr);",
			"type": "text",
			"width": 730,
			"x": -2450,
			"y": 2120
		}
